{
  "name": "market-monitor",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,css}\" \"*.{js,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css}\" \"*.{js,json}\"",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@sentry/react": "^8.55.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/ui": "^2.1.9",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.8.3",
    "vite": "^5.4.0",
    "vite-plugin-static-copy": "^1.0.6",
    "vitest": "^2.1.9"
  }
}
